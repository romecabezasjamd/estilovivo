// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  password           String
  name               String
  avatar             String?
  fullBodyAvatar     String?
  bio                String?
  mood               String?
  cycleTracking      Boolean    @default(false)
  musicSync          Boolean    @default(false)
  emailNotifications Boolean    @default(true)
  emailChat          Boolean    @default(true)
  emailFollows       Boolean    @default(true)
  emailWashing       Boolean    @default(true)
  emailChallenges    Boolean    @default(true)
  gender             String?    @default("other")
  birthDate         DateTime?
  resetToken        String?
  resetTokenExpiry  DateTime?
  isVerified        Boolean    @default(false)
  verificationToken String?
  experiencePoints  Int        @default(0)
  level             Int        @default(1)
  themePreset       String?
  customColor       String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  
  @@index([resetToken])
  @@index([verificationToken])
  
  products          Product[]
  looks             Look[]
  plannerEntries    PlannerEntry[]
  trips             Trip[]
  likes             Like[]
  comments          Comment[]
  favorites         Favorite[]
  followers         Follow[]   @relation("following")
  following         Follow[]   @relation("follower")
  chatParticipants  ConversationParticipant[]
  messages          Message[]
  notifications     Notification[]
  stories           Story[]
  challengeSubmissions ChallengeSubmission[]
  achievements        UserAchievement[]
  badges              UserBadge[]
  streak              UserStreak?
  tryonPresets        TryonPreset[]
}

model TryonPreset {
  id          String   @id @default(cuid())
  name        String
  thumbnail   String?
  layers      String   @default("[]") // JSON string of layer data
  rating      Int?
  occasion    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Product {
  id          String     @id @default(cuid())
  name        String
  description String?
  price       Float?
  brand       String?
  category    String
  size        String?
  color       String?
  condition   String     @default("new")
  season      String     @default("all")
  usageCount  Int        @default(0)
  lastWorn    DateTime?
  forSale     Boolean    @default(false)
  isWashing   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  images      ProductImage[]
  looks       Look[]
  favorites   Favorite[]
  tripGarments TripGarment[]
  
  @@index([userId, createdAt])
  @@index([forSale, category])
  @@index([userId, category])
}

model ProductImage {
  id        String     @id @default(cuid())
  url       String
  filename  String
  createdAt DateTime   @default(now())
  
  productId String
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Look {
  id          String     @id @default(cuid())
  title       String
  description String?
  isPublic    Boolean    @default(false)
  mood        String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  products    Product[]
  images      LookImage[]
  plannerEntries PlannerEntry[]
  likes       Like[]
  comments    Comment[]
  favorites   Favorite[]
  
  @@index([isPublic, createdAt])
  @@index([userId, createdAt])
}

model LookImage {
  id        String     @id @default(cuid())
  url       String
  filename  String
  createdAt DateTime   @default(now())
  
  lookId    String
  look      Look       @relation(fields: [lookId], references: [id], onDelete: Cascade)
}

model PlannerEntry {
  id        String   @id @default(cuid())
  date      String   // ISO date string YYYY-MM-DD
  lookId    String?
  look      Look?    @relation(fields: [lookId], references: [id])
  eventNote String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Trip {
  id          String        @id @default(cuid())
  destination String
  dateStart   String
  dateEnd     String
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       TripItem[]
  garments    TripGarment[]

  @@index([userId])
}

model TripItem {
  id          String  @id @default(cuid())
  label       String
  checked     Boolean @default(false)
  isEssential Boolean @default(false)
  tripId      String
  trip        Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model TripGarment {
  id        String  @id @default(cuid())
  tripId    String
  trip      Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([tripId, productId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lookId    String
  look      Look     @relation(fields: [lookId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, lookId])
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lookId    String
  look      Look      @relation(fields: [lookId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  createdAt DateTime  @default(now())
  
  @@index([lookId, createdAt])
  @@index([parentId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lookId    String?
  look      Look?    @relation(fields: [lookId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, lookId])
  @@unique([userId, productId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model Conversation {
  id            String                     @id @default(cuid())
  itemId        String?
  itemTitle     String?
  itemImage     String?
  itemOwnerId   String?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  participants  ConversationParticipant[]
  messages      Message[]
}

model ConversationParticipant {
  id             String        @id @default(cuid())
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())

  @@unique([conversationId, userId])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  imageUrl       String?
  productId      String?
  createdAt      DateTime      @default(now())
  
  @@index([conversationId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // e.g. "SALE", "CHAT", "WASHING", "INTEREST"
  content   String?
  relatedId String?  // p. ej. conversationId para CHAT
  isRead    Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Story {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "image" | "text"
  text      String?
  imageUrl  String?
  views     Int      @default(0)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

model WeeklyChallenge {
  id          String   @id @default(cuid())
  title       String
  description String
  reward      Int      @default(50)
  tag         String
  startDate   DateTime @default(now())
  endDate     DateTime
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  submissions ChallengeSubmission[]
  @@index([active])
  @@index([startDate, endDate])
}

model ChallengeSubmission {
  id          String   @id @default(cuid())
  userId      String
  challengeId String
  imageUrl    String?
  description String?
  verified    Boolean  @default(false)
  awarded     Boolean  @default(false)
  createdAt   DateTime @default(now())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge WeeklyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([challengeId])
  @@index([userId])
}

model UserAchievement {
  id             String   @id @default(cuid())
  userId         String
  achievementKey String
  title          String
  description    String
  icon           String
  xpReward       Int      @default(0)
  unlockedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementKey])
  @@index([userId])
}

model UserBadge {
  id          String   @id @default(cuid())
  userId      String
  badgeKey    String
  title       String
  description String
  icon        String
  unlockedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@index([userId])
}

model UserStreak {
  id         String    @id @default(cuid())
  userId     String    @unique
  loginCount Int       @default(0)
  lastDate   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
