# Database
DATABASE_URL="file:./dev.db"

# Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-here-minimum-32-characters"

# Server
PORT=3000
NODE_ENV=development

# SMTP — OBLIGATORIO para:
# - Recuperación de contraseña ("Olvidé mi contraseña")
# - Verificación de cuenta
# - Notificaciones de chat por email
# Sin SMTP, estas funciones NO funcionarán.
# Para Gmail: usa una "Contraseña de aplicación" (no tu contraseña normal)
# https://support.google.com/accounts/answer/185833
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="tu-email@gmail.com"
SMTP_PASS="tu-app-password"

# Para otros proveedores (Outlook, Yahoo, etc.) cambia host y puerto
# SMTP_HOST="smtp.office365.com"
# SMTP_PORT=587
# SMTP_SECURE=false

# Descomenta SOLO si tu servidor SMTP tiene certificados auto-firmados:
# SMTP_TLS_REJECT_UNAUTHORIZED=false

# URL pública del frontend (enlaces en emails)
FRONTEND_URL="http://localhost:5173"
EMAIL_FROM="Estilo Vivo <noreply@estilovivo.app>"

# Uploads
UPLOADS_DIR="./uploads"
