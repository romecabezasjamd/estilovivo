# ============= CONFIGURACIÓN DE LA APLICACIÓN =============

# Base de datos SQLite
DATABASE_URL="file:./data/dev.db"

# Server
PORT=3000
NODE_ENV=production
FRONTEND_URL="https://estilovivo.xyoncloud.win"
VITE_API_BASE="https://estilovivo.xyoncloud.win/api"

# Seguridad y AI
JWT_SECRET=tu_secreto_super_seguro
GEMINI_API_KEY=tu_api_key_de_gemini

# SMTP (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Uploads
UPLOADS_DIR="/app/uploads"

# Notas:
# - Copia este archivo a .env antes de usar.
# - El despliegue actual utiliza SQLite por defecto.
